{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Teologické texty"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "content": {
      "type": "blocks"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "teologicke-texty",
        "sviatky-svätych",
        "marianske-sviatky",
        "panove-sviatky",
        "rozne"
      ],
      "default": "teologicke-texty",
      "required": true
    },
    "published_date": {
      "type": "date",
      "required": true
    }
  }
}
